---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import MenuList from '../components/MenuList.astro';
import OrderPanel from '../components/OrderPanel.astro';
import Story from '../components/Story.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Base>
  <SiteHeader />

  <main id="main">
    <Hero />
    <HowItWorks />

    <section class="menu-section section" id="menu" aria-label="Menú y pedido">
      <div class="container">
        <div class="menu-wrap">
          <MenuList />
        </div>
      </div>
    </section>
    <OrderPanel />

    <Story />
  </main>

  <SiteFooter />
</Base>

<style>
  .menu-section {
    background: var(--bg);
    padding-block: var(--space-xl);
  }
  /* columna única, centrada y legible — el pedido vive en un cajón */
  .menu-wrap {
    max-width: 48rem;
    margin-inline: auto;
  }
</style>

<script>
  import '../scripts/order.ts';
</script>
