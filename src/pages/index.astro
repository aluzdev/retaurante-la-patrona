---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import MenuList from '../components/MenuList.astro';
import OrderPanel from '../components/OrderPanel.astro';
import Story from '../components/Story.astro';
import SiteFooter from '../components/SiteFooter.astro';
---

<Base>
  <SiteHeader />

  <main id="main">
    <Hero />
    <HowItWorks />

    <section class="menu-section section" id="menu" aria-label="Menú y pedido">
      <div class="container menu-layout">
        <div class="menu-layout__list">
          <MenuList />
        </div>
        <div class="menu-layout__aside">
          <OrderPanel />
        </div>
      </div>
    </section>

    <Story />
  </main>

  <SiteFooter />
</Base>

<style>
  .menu-section {
    background: var(--bg);
    padding-block: var(--space-xl);
  }
  .menu-layout {
    display: grid;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .menu-layout {
      grid-template-columns: minmax(0, 1fr) 22.5rem;
    }
  }
</style>

<script>
  import '../scripts/order.ts';
</script>
