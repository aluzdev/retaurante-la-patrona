---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.fullName} · Comida casera en Azcapotzalco`,
  description = `Menú y pedidos por WhatsApp de ${site.fullName}. Comida corrida casera en ${site.address.colonia}, Azcapotzalco. Reparto a domicilio en la colonia.`,
} = Astro.props;
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#4a2016" />

    <meta property="og:type" content="restaurant" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_MX" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <a class="skip-link" href="#menu">Saltar al menú</a>
    <slot />
  </body>
</html>
