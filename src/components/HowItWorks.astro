---
import Icon from './Icon.astro';

const steps = [
  {
    n: '1',
    title: 'Arma tu pedido',
    body: 'Toca los platillos que se te antojen y elige cómo los quieres. Agrega notas como “que no sea dulce” o “mucha crema”.',
  },
  {
    n: '2',
    title: 'Dinos cómo pagas',
    body: 'Efectivo, tarjeta o transferencia — y si es a domicilio, tu dirección. Así llevamos la terminal si la necesitas.',
  },
  {
    n: '3',
    title: 'Envía por WhatsApp',
    body: 'Tu mensaje se arma solito, ya redactado y clarito. Solo lo mandas y nosotros preparamos.',
  },
];
---

<section class="how" aria-label="Cómo pedir">
  <div class="container">
    <div class="how__head">
      <h2>Pedir es facilísimo</h2>
      <p>
        Sin llamadas, sin adivinar el menú y sin escribir todo a mano. En tres pasos.
      </p>
    </div>

    <ol class="how__steps">
      {
        steps.map((s) => (
          <li class="how__step">
            <span class="how__num">{s.n}</span>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </li>
        ))
      }
    </ol>

    <p class="how__foot">
      <Icon name="arrow-down" size={18} /> Empieza por elegir tus platillos
    </p>
  </div>
</section>

<style>
  .how {
    background: var(--surface);
    border-top: 1px solid var(--line-soft);
    border-bottom: 1px solid var(--line-soft);
    padding-block: var(--space-xl);
  }
  .how__head {
    max-width: 44rem;
    margin-bottom: var(--space-l);
  }
  .how__head h2 {
    font-size: var(--step-3);
    margin-bottom: 0.4rem;
  }
  .how__head p {
    color: var(--muted);
    font-size: var(--step-1);
    max-width: var(--measure);
  }

  .how__steps {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-l);
    display: grid;
    gap: var(--space-m);
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 16rem), 1fr));
    counter-reset: none;
  }
  .how__step {
    position: relative;
    padding: var(--space-m) var(--space-m) var(--space-m) var(--space-m);
  }
  .how__step:not(:last-child)::after {
    content: '';
    position: absolute;
    top: 1.6rem;
    right: -0.75rem;
    bottom: 1rem;
    width: 1px;
    background: var(--line);
  }
  .how__num {
    display: grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    margin-bottom: 0.85rem;
    border-radius: var(--r-pill);
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--guajillo);
    background: color-mix(in oklab, var(--guajillo) 12%, var(--bg));
  }
  .how__step h3 {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--step-1);
    letter-spacing: -0.01em;
    margin-bottom: 0.3rem;
  }
  .how__step p {
    color: var(--muted);
    font-size: var(--step-0);
    line-height: 1.5;
    max-width: 24rem;
  }

  .how__foot {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    color: var(--guajillo-ink);
  }

  @media (max-width: 720px) {
    .how__step::after {
      display: none !important;
    }
  }
</style>
