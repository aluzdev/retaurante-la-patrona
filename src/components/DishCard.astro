---
import type { MenuItem } from '../data/menu';
import Icon from './Icon.astro';

interface Props {
  item: MenuItem;
}
const { item } = Astro.props;
---

<article class="dish" data-dish data-id={item.id} data-name={item.name}>
  <div class="dish__text">
    <h4 class="dish__name">
      {item.name}
      {item.tag && <span class="dish__tag">{item.tag}</span>}
    </h4>
    {item.desc && <p class="dish__desc">{item.desc}</p>}
  </div>

  <button class="dish__add" type="button" data-add aria-label={`Agregar ${item.name} al pedido`}>
    <span class="dish__add-plus"><Icon name="plus" size={20} /></span>
    <span class="dish__add-count" data-add-count hidden>0</span>
  </button>
</article>

<style>
  .dish {
    display: flex;
    align-items: flex-start;
    gap: var(--space-m);
    padding: var(--space-s) 0;
    border-top: 1px solid var(--line-soft);
  }
  .dish:first-child {
    border-top: none;
  }

  .dish__text {
    flex: 1;
    min-width: 0;
  }
  .dish__name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--step-1);
    line-height: 1.15;
    letter-spacing: -0.005em;
    color: var(--ink);
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .dish__tag {
    font-family: var(--font-body);
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--cempasuchil-deep);
    transform: translateY(-1px);
  }
  .dish__desc {
    color: var(--muted);
    font-size: var(--step--1);
    line-height: 1.45;
    margin-top: 0.2rem;
    max-width: 42ch;
  }

  /* Un solo control: el botón agregar. Sin fill + shadow juntos. */
  .dish__add {
    flex-shrink: 0;
    position: relative;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    margin-top: 2px;
    border-radius: var(--r-pill);
    color: var(--guajillo-ink);
    background: color-mix(in oklab, var(--guajillo) 9%, var(--bg));
    transition:
      background-color var(--dur-fast) var(--ease-out-quart),
      color var(--dur-fast) var(--ease-out-quart),
      transform var(--dur-fast) var(--ease-out-quart);
  }
  .dish__add:hover {
    background: var(--guajillo);
    color: var(--cream);
  }
  .dish__add:active {
    transform: scale(0.9);
  }
  .dish__add-plus {
    display: grid;
    place-items: center;
    transition: transform var(--dur-mid) var(--ease-out-expo);
  }

  /* Estado agregado: el botón se vuelve marigold con el conteo */
  .dish[data-in-order] .dish__add {
    background: var(--cempasuchil);
    color: var(--barro-deep);
  }
  .dish[data-in-order] .dish__add:hover {
    background: var(--guajillo);
    color: var(--cream);
  }
  .dish[data-in-order] .dish__add-plus {
    transform: scale(0.82);
  }
  .dish__add-count {
    position: absolute;
    inset: 0;
    display: none;
    place-items: center;
    font-weight: 800;
    font-size: 0.95rem;
    font-variant-numeric: tabular-nums;
  }
  .dish[data-in-order] .dish__add-count {
    display: grid;
  }
  .dish[data-in-order] .dish__add:hover .dish__add-count {
    display: none;
  }
  .dish[data-in-order] .dish__add-plus {
    display: none;
  }
  .dish[data-in-order] .dish__add:hover .dish__add-plus {
    display: grid;
    transform: none;
  }

  .dish[data-just-added] .dish__add {
    animation: pop var(--dur-mid) var(--ease-out-expo);
  }
  @keyframes pop {
    0% {
      transform: scale(1);
    }
    45% {
      transform: scale(1.18);
    }
    100% {
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dish__add,
    .dish__add-plus,
    .dish[data-just-added] .dish__add {
      transition: none;
      animation: none;
    }
  }
</style>
