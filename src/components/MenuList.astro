---
import { menu } from '../data/menu';
import DishCard from './DishCard.astro';
---

<div class="menu-list">
  <header class="menu-list__intro">
    <p class="menu-list__kicker">La carta</p>
    <h2 class="menu-list__title">¿Qué se le antoja hoy?</h2>
    <p class="menu-list__note">
      Toca <strong>Agregar</strong> en lo que quieras. Tu pedido se va armando a la
      derecha y al final lo mandas por WhatsApp. Los precios son de referencia; el
      total te lo confirmamos por el chat.
    </p>
  </header>

  {
    menu.map((section) => (
      <section class="menu-group" id={`sec-${section.id}`} aria-labelledby={`h-${section.id}`}>
        <div class="menu-group__head">
          <p class="menu-group__kicker">{section.kicker}</p>
          <h3 class="menu-group__title" id={`h-${section.id}`}>
            {section.title}
          </h3>
          {section.blurb && <p class="menu-group__blurb">{section.blurb}</p>}
        </div>

        <div
          class="menu-group__grid"
          data-single={section.items.length === 1 ? '' : undefined}
        >
          {section.items.map((item) => (
            <DishCard item={item} />
          ))}
        </div>
      </section>
    ))
  }
</div>

<style>
  .menu-list__intro {
    margin-bottom: var(--space-l);
  }
  .menu-list__kicker {
    font-weight: 700;
    font-size: var(--step--1);
    color: var(--cempasuchil-deep);
    margin-bottom: 0.35rem;
  }
  .menu-list__title {
    font-size: var(--step-4);
    line-height: 1;
    margin-bottom: 0.7rem;
  }
  .menu-list__note {
    color: var(--muted);
    max-width: var(--measure);
    font-size: var(--step-0);
  }
  .menu-list__note strong {
    color: var(--guajillo-ink);
  }

  .menu-group {
    margin-top: var(--space-xl);
    scroll-margin-top: calc(var(--header-h) + 1rem);
  }
  .menu-group:first-of-type {
    margin-top: var(--space-l);
  }
  .menu-group__head {
    margin-bottom: var(--space-m);
  }
  .menu-group__kicker {
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: var(--muted);
    margin-bottom: 0.25rem;
  }
  .menu-group__title {
    font-size: var(--step-3);
    line-height: 1;
    margin-bottom: 0.5rem;
    padding-bottom: 0.55rem;
    border-bottom: 2px solid var(--line);
    position: relative;
  }
  .menu-group__title::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 3.2rem;
    height: 2px;
    background: var(--cempasuchil);
  }
  .menu-group__blurb {
    color: var(--muted);
    max-width: var(--measure);
    font-size: var(--step-0);
    margin-top: 0.7rem;
  }

  .menu-group__grid {
    display: grid;
    gap: var(--space-s);
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 17rem), 1fr));
    align-items: stretch;
  }
  /* A lone item (menú del día) gets a wider, feature treatment */
  .menu-group__grid[data-single] {
    grid-template-columns: minmax(0, 34rem);
  }
</style>
